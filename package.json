{
  "name": "@mizufinancial/docuflow",
  "version": "0.1.0",
  "description": "Automated documentation generation tool based on Markdown DSL and Playwright",
  "main": "dist/index.js",
  "bin": {
    "docuflow": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "start:prod": "node dist/index.js",
    "test": "vitest run --coverage",
    "build": "vite build",
    "format": "biome format --write"
  },
  "keywords": [
    "documentation",
    "playwright",
    "markdown",
    "automation",
    "dsl"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.6.2",
    "playwright": "^1.58.2",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/node": "^24.10.13",
    "@types/uniqid": "^5.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
